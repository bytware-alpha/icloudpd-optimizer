FROM docker.io/rust:1.86-bookworm AS builder
WORKDIR /src
COPY Cargo.toml Cargo.lock ./
COPY src ./src
RUN cargo build --release --locked

FROM docker.io/debian:bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    imagemagick \
    libheif-examples \
    libimage-exiftool-perl \
    libraw-bin \
  && rm -rf /var/lib/apt/lists/* \
  && printf '%s\n' \
    '#!/bin/sh' \
    'set -eu' \
    'if [ "${1:-}" = "compare" ]; then' \
    '  shift' \
    '  exec /usr/bin/compare "$@"' \
    'fi' \
    'exec /usr/bin/convert "$@"' \
    > /usr/local/bin/magick \
  && chmod +x /usr/local/bin/magick
COPY --from=builder /src/target/release/icloudpd-optimizer /usr/local/bin/icloudpd-optimizer
ENTRYPOINT ["icloudpd-optimizer"]
CMD ["--help"]
